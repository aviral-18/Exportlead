# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=brass_export
POSTGRES_USER=brass
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://brass:change_me_strong_password@postgres:5432/brass_export
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_secret
REDIS_URL=redis://:change_me_redis_secret@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_secret@redis:6379/2

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Auth (generate with: openssl rand -hex 32) ───────────────────────────────
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=brass-export-intelligence
AWS_S3_REGION=ap-south-1

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_secret
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_secret

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Commercial API keys (optional) ───────────────────────────────────────────
VOLZA_API_KEY=
VOLZA_USERNAME=
VOLZA_PASSWORD=
IMPORT_YETI_API_KEY=
IMPORT_YETI_SESSION_COOKIE=
EXPORT_GENIUS_API_KEY=
EXPORT_GENIUS_USERNAME=
EXPORT_GENIUS_PASSWORD=
DATAMYNE_USERNAME=
DATAMYNE_PASSWORD=
PANJIVA_API_KEY=
PANJIVA_USERNAME=
PANJIVA_PASSWORD=
INDIA_EXPORT_DATA_API_KEY=

# ── Public APIs ───────────────────────────────────────────────────────────────
UN_COMTRADE_API_KEY=
TRADE_MAP_USERNAME=
TRADE_MAP_PASSWORD=
SAM_GOV_API_KEY=

# ── Pipeline settings ─────────────────────────────────────────────────────────
BATCH_SIZE=1000
DEDUP_THRESHOLD=0.85
ENTITY_RESOLUTION_WORKERS=8
HEADLESS=true
REQUESTS_PER_SECOND=2.0
PROXY_URL=
PROXY_ROTATION_ENABLED=false

{
  "permissions": {
    "allow": [
      "PowerShell(Invoke-RestMethod http://localhost:8000/health -ErrorAction SilentlyContinue)",
      "PowerShell(New-Item -ItemType Directory -Force -Path d:\\\\BRASS\\\\src\\\\scoring)",
      "PowerShell(\"ok\")",
      "Bash(curl -s http://localhost:8000/health)",
      "Bash(curl -s \"http://localhost:8000/api/v1/analytics/overview\")",
      "Bash(python -m json.tool)",
      "Bash(curl -s \"http://localhost:8000/api/v1/dashboard/top-buyers?limit=5\")",
      "Bash(curl -s \"http://localhost:8000/api/v1/dashboard/untapped?limit=3\")",
      "PowerShell(taskkill /F /IM python.exe 2>$null)",

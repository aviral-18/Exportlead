      "PowerShell(Start-Sleep -Seconds 7; try { \\(Invoke-WebRequest \"http://localhost:8000/health\" -UseBasicParsing -TimeoutSec 5\\).Content } catch { \"not ready: $_\" })",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(echo \"pid=$!\")",
      "Bash(curl -s http://localhost:3000 -o /dev/null -w \"%{http_code}\")",
      "Bash(disown)",
      "Bash(nohup npm run dev)",
      "Bash(curl -s http://localhost:3000 -o /dev/null -w \"status=%{http_code}\")",
      "Bash(cat /tmp/next_dev.log | tail -40)",
      "Read(//tmp/**)"
